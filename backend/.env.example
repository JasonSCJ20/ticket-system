# Environment variables for the ticket system backend
# Copy this file to .env and fill in your values

# Database URL (default is SQLite)
DATABASE_URL=sqlite:///./ticket_system.db

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Chat ID for monthly reports (optional)
MONTHLY_REPORT_CHAT_ID=

# Secret key for JWT (change in production)
SECRET_KEY=PLEASE_CHANGE_ME